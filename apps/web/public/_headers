# Cloudflare Pages/Workers 静的アセット向けキャッシュ設定。
# Vite の chunk hash が毎デプロイで変わる前提で、index.html は毎回 revalidate、
# assets/ (hash 付き) は 1 年 immutable。
# これがないと、古い index.html がキャッシュされたまま新 deploy の chunk に
# アクセスしてしまい、SPA fallback で HTML が返って MIME エラー → クラッシュ
# ループ (iOS Safari でよく起きる) を引き起こす。

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# OAuth client metadata は dev.aozoraquest.app からも cross-origin で
# 取得するので CORS 解放。redirect_uris にもう片方の domain も入っているので
# 両 origin から同一 metadata を共有して使う。
/client-metadata.json
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300
