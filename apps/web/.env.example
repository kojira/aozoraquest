# 主管理者の DID (カンマ区切りで複数可)。
# boot 時にこの DID の PDS からフラグ・ディレクトリ・プロンプトを読む。
VITE_ADMIN_DIDS=did:plc:47skrewud2vjha6o57wzzxjw

# OAuth client_id / redirect_uris の origin。build 時に client-metadata.json を生成する元。
# 未設定だと build が失敗する (silent に誤デプロイを防ぐため)。
# 本家 prod: https://aozoraquest.app   dev: https://dev.aozoraquest.app   ローカル: http://127.0.0.1:9999
# fork する場合は自分のドメインに置き換える (例: https://example.com)
VITE_APP_URL=https://aozoraquest.app

# OAuth client_metadata の表示名 (任意, デフォルト "Aozora Quest")
# VITE_APP_NAME=Aozora Quest

# プロジェクト固有の NSID prefix (必須)。fork はここを変える。
# 本家: app.aozoraquest   fork 例: com.example.myapp
VITE_NSID_ROOT=app.aozoraquest

# 同一プロジェクト内で env を分離する suffix (任意)。
# user 記録 (analysis/profile/spiritChat/questLog/cardDraw) のみに付与され、
# admin 記録は全 env 共有のためここの影響を受けない。
# prod: 未指定   dev: dev   ローカル: local
# VITE_NSID_ENV=dev
