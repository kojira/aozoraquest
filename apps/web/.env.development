# `pnpm dev` 用のデフォルト env。`.env.local` で個別上書き可。
# (本番 / dev branch deploy 用の値は Cloudflare Workers Builds の env vars で別途指定)

# OAuth は ローカルでも loopback URI 必須 (RFC 8252)。
# vite dev server はこれを location.origin から導出するので未指定でも動くが、
# build を試したい時のために 127.0.0.1 を入れておく。
VITE_APP_URL=http://127.0.0.1:9999

# ローカル PDS 書き込みは prod とも dev branch deploy とも分離
VITE_NSID_ROOT=app.aozoraquest
VITE_NSID_ENV=local
