# 管理者として認可する DID のホワイトリスト (カンマ区切り)。
# ログイン DID がこの中に無ければ admin UI には入れない。
VITE_ADMIN_DIDS=did:plc:47skrewud2vjha6o57wzzxjw

# OAuth client_id / redirect_uris の origin。build 時に client-metadata.json を生成する元 (必須)。
# 本家: https://admin.aozoraquest.app   ローカル: http://127.0.0.1:9998
VITE_APP_URL=https://admin.aozoraquest.app

# OAuth client_metadata の表示名 (任意, デフォルト "Aozora Quest Admin")
# VITE_APP_NAME=Aozora Quest Admin

# プロジェクト固有の NSID prefix (必須)。web 側と同じ値を使う。
# 本家: app.aozoraquest   fork 例: com.example.myapp
VITE_NSID_ROOT=app.aozoraquest
